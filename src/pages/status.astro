---
import Base from '../layouts/Base.astro';

const services = [
  { name: "Web App", description: "app.thefantasticleagues.com", status: "operational", uptime: "100%" },
  { name: "API Server", description: "Express API + WebSocket", status: "operational", uptime: "100%" },
  { name: "Database", description: "PostgreSQL (Supabase)", status: "operational", uptime: "100%" },
  { name: "Authentication", description: "Supabase Auth (Google/Email)", status: "operational", uptime: "100%" },
  { name: "MLB Stats Sync", description: "Daily player + stats sync via MLB API", status: "operational", uptime: "100%" },
  { name: "AI Services", description: "Google Gemini + Anthropic Claude", status: "operational", uptime: "100%" },
  { name: "Email", description: "Transactional email via Resend", status: "operational", uptime: "100%" },
  { name: "Marketing Site", description: "www.thefantasticleagues.com", status: "operational", uptime: "100%" },
];

function statusColor(s: string) {
  if (s === "operational") return { bg: "bg-emerald-500", text: "text-emerald-400", label: "Operational" };
  if (s === "degraded") return { bg: "bg-amber-500", text: "text-amber-400", label: "Degraded" };
  if (s === "outage") return { bg: "bg-red-500", text: "text-red-400", label: "Major Outage" };
  return { bg: "bg-slate-500", text: "text-slate-400", label: "Unknown" };
}

const allOperational = services.every(s => s.status === "operational");

const recentDays = [
  { date: "Apr 10", incidents: false },
  { date: "Apr 9", incidents: false },
  { date: "Apr 8", incidents: false },
  { date: "Apr 7", incidents: false },
  { date: "Apr 6", incidents: false },
  { date: "Apr 5", incidents: false },
  { date: "Apr 4", incidents: false },
];
---

<Base title="System Status">
  <section class="max-w-3xl mx-auto px-4 py-20">
    <!-- Header -->
    <div class="flex items-center justify-between mb-12">
      <div>
        <h1 class="text-3xl font-bold text-white mb-1">System Status</h1>
        <p class="text-sm text-slate-400">Current operational status of all TFL services.</p>
      </div>
      <div class={`px-4 py-2 rounded-xl text-sm font-semibold ${allOperational ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-amber-500/10 text-amber-400 border border-amber-500/20'}`}>
        {allOperational ? "All Systems Operational" : "Some Issues Detected"}
      </div>
    </div>

    <!-- Services with individual uptime bars -->
    <div class="space-y-6 mb-16">
      {services.map((service) => {
        const sc = statusColor(service.status);
        return (
          <div>
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2.5">
                <div class={`w-2.5 h-2.5 rounded-full ${sc.bg}`} />
                <span class="text-sm font-medium text-white">{service.name}</span>
                <span class="text-xs text-slate-600 hidden sm:inline">{service.description}</span>
              </div>
              <span class={`text-xs font-semibold ${sc.text}`}>{service.uptime}</span>
            </div>
            <div class="flex gap-[2px] h-[30px]">
              {Array.from({ length: 90 }, (_, i) => (
                <div
                  class="flex-1 rounded-[2px] bg-emerald-500/80 hover:bg-emerald-400 transition-colors cursor-default"
                  title={`${90 - i} days ago — No downtime`}
                />
              ))}
            </div>
            <div class="flex items-center justify-between mt-1">
              <span class="text-[10px] text-slate-600">90 days ago</span>
              <span class="text-[10px] text-slate-600">Today</span>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Past incidents -->
    <div>
      <h2 class="text-lg font-bold text-white mb-6 pb-3 border-b border-white/5">Past Incidents</h2>
      <div class="space-y-6">
        {recentDays.map((day) => (
          <div>
            <h3 class="text-sm font-semibold text-white mb-2">{day.date}, 2026</h3>
            <p class="text-sm text-slate-500 italic">No incidents reported.</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-14 text-center">
      <p class="text-xs text-slate-600">
        For urgent issues, contact <a href="mailto:support@thefantasticleagues.com" class="text-brand-400 hover:underline">support@thefantasticleagues.com</a>
      </p>
    </div>
  </section>
</Base>
