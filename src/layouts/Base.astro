---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Fantasy baseball league management powered by AI. Draft grades, trade analysis, weekly insights — all tailored to your league." } = Astro.props;
const APP_URL = "https://app.thefantasticleagues.com";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | The Fantastic Leagues</title>

    <!-- Google Analytics 4 (marketing site) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-5FS3SKCH55"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5FS3SKCH55');
    </script>
  </head>
  <body class="min-h-screen bg-[#0f172a] text-slate-200">
    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 bg-[#0f172a]/80 backdrop-blur-xl border-b border-white/5">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-white">
          <span class="text-2xl">&#9918;</span>
          <span>TFL</span>
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-400">
          <a href="/#formats" class="hover:text-white transition-colors">Formats</a>
          <a href="/#features" class="hover:text-white transition-colors">Features</a>
          <a href="/#pricing" class="hover:text-white transition-colors">Pricing</a>
          <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        </div>
        <div class="flex items-center gap-3">
          <a href={`${APP_URL}/login`} class="text-sm text-slate-400 hover:text-white transition-colors">Sign In</a>
          <a href={`${APP_URL}/signup`} class="text-sm bg-brand-500 hover:bg-brand-600 text-white px-4 py-2 rounded-lg font-semibold transition-colors">Start Free</a>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 mt-24">
      <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
        <div>
          <h4 class="font-semibold text-white mb-3">Product</h4>
          <ul class="space-y-2 text-slate-400">
            <li><a href="/#features" class="hover:text-white">Features</a></li>
            <li><a href="/#pricing" class="hover:text-white">Pricing</a></li>
            <li><a href="/#formats" class="hover:text-white">Formats</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-white mb-3">Resources</h4>
          <ul class="space-y-2 text-slate-400">
            <li><a href="/blog" class="hover:text-white">Blog</a></li>
            <li><a href="/status" class="hover:text-white">Status</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-white mb-3">Company</h4>
          <ul class="space-y-2 text-slate-400">
            <li><a href="/about" class="hover:text-white">About</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-white mb-3">App</h4>
          <ul class="space-y-2 text-slate-400">
            <li><a href={`${APP_URL}/login`} class="hover:text-white">Sign In</a></li>
            <li><a href={`${APP_URL}/signup`} class="hover:text-white">Create Account</a></li>
          </ul>
        </div>
      </div>
      <div class="text-center text-xs text-slate-500 pb-8">
        &copy; {new Date().getFullYear()} The Fantastic Leagues. All rights reserved.
      </div>
    </footer>
  </body>
</html>
