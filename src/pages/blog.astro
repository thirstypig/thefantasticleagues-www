---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<Base title="Blog">
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-white mb-4">Blog</h1>
    <p class="text-slate-400 mb-10">Fantasy baseball tips, draft strategy, and league management insights.</p>

    {posts.length === 0 ? (
      <div class="bg-white/5 border border-white/10 rounded-2xl p-8 text-center">
        <p class="text-slate-400">Coming soon. First posts launching with the 2026 season.</p>
      </div>
    ) : (
      <div class="space-y-8">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="block bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-brand-500/30 transition-colors group">
            <div class="flex items-center gap-3 mb-3">
              <time class="text-xs text-slate-500">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
              {post.data.tags?.map((tag: string) => (
                <span class="text-[10px] font-bold uppercase text-brand-400 bg-brand-400/10 px-2 py-0.5 rounded-full border border-brand-400/20">{tag}</span>
              ))}
            </div>
            <h2 class="text-xl font-bold text-white group-hover:text-brand-400 transition-colors mb-2">{post.data.title}</h2>
            <p class="text-sm text-slate-400 line-clamp-2">{post.data.description}</p>
            <p class="text-[10px] text-slate-600 mt-2 italic">Written with AI</p>
          </a>
        ))}
      </div>
    )}
  </section>
</Base>
