---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const now = new Date();
  const posts = (await getCollection('blog')).filter(
    (post) => new Date(post.data.date) <= now
  );
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();
const APP_URL = "https://app.thefantasticleagues.com";

// Estimate reading time (~200 words per minute)
const words = post.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.round(words / 200));
---

<Base title={post.data.title} description={post.data.description}>
  <article class="max-w-[720px] mx-auto px-5 md:px-0 py-20">
    <a href="/blog" class="text-sm text-slate-500 hover:text-white transition-colors mb-8 inline-block">&larr; Back to Blog</a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-5 flex-wrap text-sm text-slate-500">
        <time>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
        <span class="text-slate-700">·</span>
        <span>{readingTime} min read</span>
        {post.data.tags?.map((tag: string) => (
          <span class="text-[10px] font-bold uppercase text-brand-400 bg-brand-400/10 px-2 py-0.5 rounded-full border border-brand-400/20">{tag}</span>
        ))}
      </div>
      <h1 class="text-4xl md:text-[44px] font-bold text-[#f1f5f9] leading-[1.15] tracking-tight mb-5">{post.data.title}</h1>
      <p class="text-lg text-slate-400 leading-relaxed">{post.data.description}</p>
      <div class="mt-6 flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-brand-500/20 border border-brand-500/30 flex items-center justify-center text-sm">⚾</div>
        <div>
          <div class="text-sm font-medium text-slate-300">{post.data.author}</div>
          <div class="text-xs text-slate-600 italic">Written with AI</div>
        </div>
      </div>
    </header>

    <!-- Hero image -->
    {post.data.heroImage && (
      <figure class="mb-14">
        <img
          src={post.data.heroImage}
          alt={post.data.heroAlt || post.data.title}
          class="w-full rounded-2xl object-cover max-h-[400px] border border-white/[0.06]"
          loading="eager"
        />
        {post.data.heroCredit && (
          <figcaption class="text-xs text-slate-600 mt-3 text-center">{post.data.heroCredit}</figcaption>
        )}
      </figure>
    )}

    <!-- Article body -->
    <div class="blog-content">
      <Content />
    </div>

    <!-- End CTA -->
    <div class="mt-20 py-10 px-8 bg-white/[0.03] border border-white/[0.06] rounded-2xl text-center">
      <h3 class="text-xl font-bold text-white mb-2">Ready to try it?</h3>
      <p class="text-sm text-slate-400 mb-6">Create your league in minutes. Free to use — no credit card required.</p>
      <a href={`${APP_URL}/signup`} class="inline-block bg-brand-500 hover:bg-brand-600 text-white px-8 py-3 rounded-xl font-semibold text-sm transition-colors">
        Create Your League
      </a>
    </div>
  </article>
</Base>

<style is:global>
  /* ── Blog Typography System ──
     Based on: Stripe (18px/1.56), Linear (#f4f5f8 on dark),
     Vercel (720px column), Tailwind prose-lg baselines.
     See /deepen-plan research for full sourcing. */

  .blog-content {
    font-size: 18px;
    line-height: 1.75;
    color: #cbd5e1;
    letter-spacing: 0.005em;
  }

  /* ── Paragraphs ── */
  .blog-content p {
    margin-bottom: 1.75rem;
  }

  /* ── Headers ── */
  .blog-content h2 {
    font-size: 1.625rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .blog-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #e2e8f0;
    line-height: 1.4;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  /* ── Links ── */
  .blog-content a {
    color: #60a5fa;
    text-decoration: none;
    transition: color 0.15s;
  }
  .blog-content a:hover {
    color: #93c5fd;
    text-decoration: underline;
  }

  /* ── Bold & Emphasis ── */
  .blog-content strong {
    color: #f1f5f9;
    font-weight: 600;
  }
  .blog-content em {
    color: #94a3b8;
  }

  /* ── Blockquotes (pull quotes) ── */
  .blog-content blockquote {
    border-left: 3px solid #3b82f6;
    background: rgba(59, 130, 246, 0.04);
    border-radius: 0 12px 12px 0;
    padding: 1.25rem 1.5rem;
    margin: 2.5rem 0;
    font-size: 1.05rem;
    color: #e2e8f0;
    font-style: normal;
  }
  .blog-content blockquote p {
    margin-bottom: 0;
  }

  /* ── TL;DR box ── */
  .blog-content .tldr,
  .blog-content h2#tldr + p,
  .blog-content h2:first-child + p {
    /* Targets the paragraph right after the TL;DR heading */
  }

  /* ── Lists ── */
  .blog-content ul,
  .blog-content ol {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }
  .blog-content li {
    margin-bottom: 0.5rem;
    color: #cbd5e1;
  }
  .blog-content ul li::marker {
    color: #3b82f6;
  }

  /* ── Horizontal rules ── */
  .blog-content hr {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin: 3rem 0;
  }

  /* ── Images within content ── */
  .blog-content img {
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    margin: 2rem 0;
  }

  /* ── Inline code ── */
  .blog-content code {
    background: rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 0.9em;
    color: #e2e8f0;
  }
</style>
