---
import Base from '../layouts/Base.astro';
---

<Base title="Changelog">
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-white mb-4">Changelog</h1>
    <p class="text-slate-400 mb-10">What's new in The Fantastic Leagues.</p>
    <div class="bg-white/5 border border-white/10 rounded-2xl p-8 text-center">
      <p class="text-slate-400">Changelog entries will be managed via Tina CMS. Check back soon.</p>
    </div>
  </section>
</Base>
