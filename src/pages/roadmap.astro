---
import Base from '../layouts/Base.astro';
---

<Base title="Roadmap">
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-white mb-4">Roadmap</h1>
    <p class="text-slate-400 mb-10">Where The Fantastic Leagues is headed.</p>

    <div class="space-y-6">
      <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-[10px] font-bold uppercase text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded-full border border-emerald-400/20">Live</span>
          <h3 class="font-semibold text-white">2026 Season</h3>
        </div>
        <p class="text-sm text-slate-400">Auction draft, rotisserie standings, AI insights, commissioner tools, league history import, real-time stats.</p>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-[10px] font-bold uppercase text-amber-400 bg-amber-400/10 px-2 py-0.5 rounded-full border border-amber-400/20">In Progress</span>
          <h3 class="font-semibold text-white">Multi-Sport Expansion</h3>
        </div>
        <p class="text-sm text-slate-400">Fantasy football, March Madness brackets, pick'em contests. Same AI-powered platform, new sports.</p>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-[10px] font-bold uppercase text-slate-400 bg-white/5 px-2 py-0.5 rounded-full border border-white/10">Planned</span>
          <h3 class="font-semibold text-white">Pro & Elite Tiers</h3>
        </div>
        <p class="text-sm text-slate-400">Stripe payments, advanced AI models, white-label branding, API access, multi-league management.</p>
      </div>
    </div>
  </section>
</Base>
