---
import Base from '../layouts/Base.astro';
// Blog posts will be loaded from Tina CMS content/blog/*.mdx
// For now, show a placeholder
---

<Base title="Blog">
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-white mb-4">Blog</h1>
    <p class="text-slate-400 mb-10">Fantasy baseball tips, draft strategy, and league management insights.</p>
    <div class="bg-white/5 border border-white/10 rounded-2xl p-8 text-center">
      <p class="text-slate-400">Coming soon. First posts launching with the 2026 season.</p>
    </div>
  </section>
</Base>
